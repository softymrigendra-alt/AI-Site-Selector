# Copy this file to .env.local and fill in your keys.
# At least one LLM key is required for AI insights in V1.
# Groq is tried first (free tier, fast). Anthropic is fallback.
# If neither key is set, a rule-based fallback is used.

# Groq (free tier) — https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Anthropic (fallback) — https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# White-label: override the app name shown in the header
# VITE_COMPANY_NAME=Your Company Name
